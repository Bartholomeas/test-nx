{
  "name": "@mono-repo-backend/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev:users2": "nx serve users2-backend",
    "dev:admin2": "nx serve admin2-backend",
    "dev:manage2": "nx serve manage2-backend",
    "dev:all": "nx run-many -t serve --all --parallel",
    "build:all": "nx run-many -t build --all --parallel",
    "build:users2": "nx build users2-backend",
    "build:admin2": "nx build admin2-backend",
    "build:manage2": "nx build manage2-backend",
    "build:affected": "nx affected -t build",
    "test:all": "nx run-many -t test --all --parallel",
    "test:affected": "nx affected -t test",
    "lint:all": "nx run-many -t lint --all --parallel",
    "lint:affected": "nx affected -t lint",
    "lint:users2": "nx lint users2-backend",
    "lint:admin2": "nx lint admin2-backend",
    "lint:manage2": "nx lint manage2-backend",
    "migration:generate": "TS_NODE_PROJECT=tsconfig.base.json npx typeorm-ts-node-commonjs migration:generate -d apps/users2-backend/data-source.ts",
    "migration:run": "TS_NODE_PROJECT=tsconfig.base.json npx typeorm-ts-node-commonjs migration:run -d apps/users2-backend/data-source.ts",
    "migration:revert": "TS_NODE_PROJECT=tsconfig.base.json npx typeorm-ts-node-commonjs migration:revert -d apps/users2-backend/data-source.ts",
    "migration:show": "TS_NODE_PROJECT=tsconfig.base.json npx typeorm-ts-node-commonjs migration:show -d apps/users2-backend/data-source.ts",
    "format:check": "nx format:check",
    "format:write": "nx format:write",
    "lint": "npx nx run-many --target=lint --all",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix"
    ],
    "*.{ts,js,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.17",
    "@nx/eslint": "22.6.1",
    "@nx/eslint-plugin": "22.6.1",
    "@nx/jest": "22.6.1",
    "@nx/js": "22.6.1",
    "@nx/nest": "^22.6.1",
    "@nx/node": "^22.6.1",
    "@nx/web": "22.6.1",
    "@nx/webpack": "22.6.1",
    "@nx/workspace": "22.6.1",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/node": "24.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "lint-staged": "^16.4.0",
    "nx": "22.6.1",
    "prettier": "~3.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1017.0",
    "@aws-sdk/client-s3": "^3.1017.0",
    "@aws-sdk/client-sqs": "^3.1017.0",
    "@aws-sdk/s3-request-presigner": "^3.1017.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "aws-jwt-verify": "^5.1.1",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "joi": "^18.1.1",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "typeorm-naming-strategies": "^4.1.0"
  }
}
